# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def removeNthFromEnd_oneround(self, head: Optional[ListNode], n: int) -> Optional[ListNode]:
        #keep two pointers, they spanned over n nodes
        dummy = ListNode(-1)
        dummy.next = head

        pt1 = pt2 = dummy

        i = 0 
        #walk n step
        while i < n and pt2:
            pt2 = pt2.next
            i += 1

        #not long enough
        if i < n -1:
            return None

        while pt2.next:
            pt2 = pt2.next
            pt1 = pt1.next
        
        # remove p1's next
        tmp = pt1.next
        pt1.next = tmp.next

        return dummy.next
    def removeNthFromEnd(self, head: Optional[ListNode], n: int) -> Optional[ListNode]:
        # use two pointers.
        # need to know the length of the list.
        # handle special case.

        len = 0
        iter = head
        while iter:
            iter = iter.next
            len += 1
        # n is begger than the length of the list.
        if n > len:
            return None
        
        dummy = ListNode(-1)
        dummy.next = head

        steps = len - n
        pt1 = dummy
        pt2 = head

        if steps == 0:
            dummy.next = head.next
            return dummy.next

        for i in range(steps):
            pt1 = pt1.next
            pt2 = pt2.next
            if i == (steps -1):
                pt1.next = pt2.next
        
        return dummy.next
                
