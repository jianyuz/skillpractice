class Solution:
 #rolling hash
 def strStr(self, haystack: str, needle: str) -> int:
        if needle == "":
            return 0

        m, n = len(haystack), len(needle)
        if n > m:
            return -1

        base = 256          # number of possible characters
        mod = 10**9 + 7     # large prime to avoid overflow

        # compute base^(m-1) % mod
        high_base = pow(base, n - 1, mod)

        # helper: convert char to int
        def char_code(c):
            return ord(c)

        # initial hash for needle and first window
        needle_hash = 0
        window_hash = 0

        for i in range(n):
            needle_hash = (needle_hash * base + char_code(needle[i])) % mod
            window_hash = (window_hash * base + char_code(haystack[i])) % mod

        # slide over haystack
        for i in range(m - n + 1):
            if needle_hash == window_hash:
                # double-check to avoid hash collision
                if haystack[i:i+n] == needle:
                    return i

            # update rolling hash
            if i + n < m:
                window_hash = (
                    window_hash
                    - char_code(haystack[i]) * high_base
                ) * base + char_code(haystack[i + n])
                window_hash %= mod

        return -1
 #O(n+M)
 def strStr(self, haystack: str, needle: str) -> int:
        #how do I preprocess it KMP, reuse previous match
        if not needle:
            return -1
        
        #build prefix
        prefix = [0] * len(needle)
        j = 0 #matched prefix
        for i in range(1, len(needle)):
            #mismatch
            while j>0 and needle[j] != needle[i]:
                j = prefix[j-1]
            if needle[j] == needle[i]:
                j += 1
            prefix[i] = j
        
        j = 0 # index for needle
        # i index for haystack
        for i in range(len(haystack)):
            while j> 0 and haystack[i] != needle[j]:
                j = prefix[j-1]
            if haystack[i] == needle[j]:
                j += 1
            #reach to the end
            if j == len(needle):
                return i - j + 1
        return -1

    def strStr(self, haystack: str, needle: str) -> int:
        #find first place start with first letter of needle.
        #compre letter by letter to its full length.
        # then next first letter of needle. repeat

        fc = needle[0]
        index = 0
        n_index = 0
        ret = -1
        while index < len(haystack):
            c = haystack[index]
            if c == fc:
                ret = index
                index += 1
                n_index += 1
                rc_index = -1 # retrace
                while index < len(haystack) and n_index < len(needle) and haystack[index] == needle[n_index]:
                    if fc == haystack[index] and rc_index == -1:
                        rc_index = index
                    index += 1
                    n_index += 1
                    
                #print(f"index={index}, n_index={n_index}")
                if n_index == len(needle) and index <= len(haystack):
                    return ret
                else:
                    #reset ret index
                    ret = -1
                    n_index = 0
                    if rc_index != -1:
                        index = rc_index
            else:
                index += 1
        return ret
                
                
